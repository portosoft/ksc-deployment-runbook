# Configurações para Automação KSC (TEMPLATE)
# INSTRUÇÕES:
# 1. Renomeie este arquivo para .env
# 2. Preencha os valores abaixo com as credenciais reais
# 3. O arquivo .env é ignorado pelo Git (conforme .gitignore)

# Acesso SSH ao Servidor
KSC_HOST=192.168.100.5
KSC_USER=suporte
KSC_PASS=sua_senha_ssh_aqui

# Configurações de Banco de Dados (PostgreSQL)
KSC_DB_PASS=sua_senha_db_aqui

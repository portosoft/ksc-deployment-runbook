# KSC Deployment - Template de Variáveis
# INSTRUÇÕES:
# 1. Copie este arquivo: cp configs/ksc_vars.env.example configs/.env
# 2. Preencha com os valores reais
# 3. NUNCA commite o arquivo .env

# Acesso SSH ao Servidor KSC
KSC_HOST=<ip-ou-fqdn-do-servidor>
KSC_USER=<usuario-ssh>
KSC_PASS=<senha-ssh>

# PostgreSQL
KSC_DB_PASS=<senha-do-kluser-no-postgres>

# FQDN do servidor KSC
KSC_FQDN=kscserver.exemplo.ts.net

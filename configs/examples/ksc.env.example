# Configurações de Servidor KSC
KSC_HOSTNAME=<PREENCHER: hostname ou IP do servidor KSC>
KSC_WEB_PORT=8080
KSC_WEB_SSL_PORT=8443

# Banco de Dados PostgreSQL
KSC_DB_NAME=ksc
KSC_IAM_DB_NAME=ksciam
KSC_DB_USER=kscdbuser
KSC_IAM_DB_USER=ksciamuser
KSC_DB_PORT=5432
KSC_DB_HOST=localhost
KSC_DB_PASS=<PREENCHER: gerar com openssl rand -base64 24>

# Configurações Adicionais
KSC_MANAGE_FIREWALL=true
POSTGRESQL_SERVICE_NAME=postgresql-16

# Configurações de Servidor KSC
KSC_FQDN=<PREENCHER: FQDN do servidor KSC>
KSC_HOST=<PREENCHER: hostname ou IP do servidor KSC>
KSC_WEB_PORT=443

# Banco de Dados PostgreSQL
KSC_IAM_NAME=ksciam
KSC_DB_USER=kscdbuser
KSC_DB_PORT=5432
KSC_DB_HOST=localhost
KSC_DB_PASS=<PREENCHER: gerar com openssl rand -base64 24>

# Autenticação e Acesso
KSC_ADMIN_USER=KLAdmins
KSC_ADMIN_PASS=<PREENCHER: senha do administrador KSC>
